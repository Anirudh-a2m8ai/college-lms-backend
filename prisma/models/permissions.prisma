model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  tag             String
  isActive        Boolean          @default(true)
  roles           Role[]
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  isDeleted       Boolean          @default(false)
  deleteAt        DateTime?
}
