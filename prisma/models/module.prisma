model Module {
  id          String       @id @default(uuid())
  logicalId   String       @default(uuid())
  title       String
  description String?
  overview    String?
  moduleMap   ModuleMap[]
  chapterMap  ChapterMap[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?
  deleteAt    DateTime?
}
