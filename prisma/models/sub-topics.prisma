model SubTopics {
  id          String        @id @default(uuid())
  logicalId   String        @default(uuid())
  title       String
  isMandatory Boolean       @default(false)
  content     String
  examples    Json?
  image       Json?
  subTopicMap subTopicMap[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  deleteAt    DateTime?
}
